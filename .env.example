# Copy this file to .env before running docker compose.

# Local desktop HTTP port exposed by the Caddy proxy container.
HOUSEWORK_HTTP_PORT=8080

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=replace-with-a-long-random-secret

# Google OAuth web client ID.
GOOGLE_CLIENT_ID=replace-with-your-google-client-id

# App bearer-token lifetime in seconds. Default is 30 days.
SESSION_MAX_AGE_SECONDS=2592000
